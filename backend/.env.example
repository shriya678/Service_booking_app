# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

PORT=4000
NODE_ENV=development

# Postgres connection string. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# The defaults below match docker-compose.yml — change both if you change one.
DATABASE_URL=postgresql://app:app@localhost:5433/service_booking?schema=public

# Origin allowed by CORS. The frontend dev server runs here.
# In production, point this at your deployed frontend domain.
FRONTEND_URL=http://localhost:5173

# Secret used to sign session JWTs. CHANGE THIS in real environments —
# anyone with this value can forge a valid session.
# Generate a strong one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# How long a session lasts. Accepts string ("7d", "1h") or seconds.
JWT_EXPIRES_IN=7d
